# Copy this to .env and fill in your values.

GROQ_API_KEY=your_groq_api_key_here

# Optional -- overrides the default model (llama-3.3-70b-versatile).
SEARCH_ORCHESTRATOR_MODEL=llama-3.3-70b-versatile

# Read-only connection to the FMOH warehouse Postgres instance that has
# dim_dashboard_mapping. If unset, dashboard-level rows are simply skipped
# and the catalog falls back to whatever's in chart_metadata.parquet.
WAREHOUSE_DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Path to the chart-level metadata parquet (one row per chart/visual inside
# a dashboard). Defaults to chart_metadata.parquet next to main.py -- just
# drop the file in at that path, no config change needed. See metadata.py
# for the expected columns.
CHART_METADATA_PARQUET=chart_metadata.parquet

PORT=8600
ALLOWED_ORIGINS=*
